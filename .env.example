# =============================================================================
#  Шаблон переменных окружения для развёртывания «Садовод» через Docker Compose.
#  Скопируйте этот файл в .env и подставьте свои значения:
#      cp .env.example .env       (Linux/macOS)
#      copy .env.example .env     (Windows)
#  Файл .env содержит секреты и НЕ коммитится в репозиторий (см. .gitignore).
# =============================================================================

# --- SQL Server -------------------------------------------------------------
# Пароль системного администратора (sa). Требования SQL Server: минимум 8 символов,
# и как минимум три из четырёх категорий: заглавные, строчные, цифры, спецсимволы.
MSSQL_SA_PASSWORD=Change_This_Str0ng_Pass!

# --- Строка подключения приложения -----------------------------------------
# Server=db — имя сервиса БД внутри сети Compose. Пароль ДОЛЖЕН совпадать
# с MSSQL_SA_PASSWORD выше.
ConnectionStrings__DefaultConnection=Server=db;Database=SadovodShop;User Id=sa;Password=Change_This_Str0ng_Pass!;TrustServerCertificate=True;MultipleActiveResultSets=true

# --- Web push (VAPID) -------------------------------------------------------
# Сгенерируйте собственную пару ключей VAPID для production.
PushSettings__Subject=mailto:admin@sadovod.ru
PushSettings__PublicKey=
PushSettings__PrivateKey=

# --- Публикация сайта -------------------------------------------------------
# Внешний порт, на котором сайт будет доступен: http://localhost:<WEB_PORT>
WEB_PORT=8080

# Окружение ASP.NET Core (Production | Development).
ASPNETCORE_ENVIRONMENT=Production
