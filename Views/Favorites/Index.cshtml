@model IReadOnlyList<Product>
@{
    ViewData["Title"] = "Избранное";
}
<h1 class="mb-3">❤ Избранное</h1>

<div id="fav-empty" class="alert alert-info @(Model.Count == 0 ? "" : "d-none")">
    Список избранного пуст. Загляните в
    <a asp-controller="Products" asp-action="Index">каталог</a>
    и отметьте понравившиеся товары значком ❤.
</div>

<div id="fav-grid" class="row g-3 @(Model.Count == 0 ? "d-none" : "")">
    @foreach (var p in Model)
    {
        <div class="col-12 col-sm-6 col-lg-4 col-xl-3" data-fav-card>
            <div class="card sadovod-card h-100">
                <a asp-controller="Products" asp-action="Details" asp-route-id="@p.Id">
                    <img src="@(p.ImageUrl ?? "/images/products/no-photo.png")" class="card-img-top" alt="@p.Name" />
                </a>
                <div class="card-body d-flex flex-column">
                    <h6 class="card-title">
                        <a asp-controller="Products" asp-action="Details" asp-route-id="@p.Id" class="text-reset text-decoration-none">@p.Name</a>
                    </h6>
                    <div class="small text-muted mb-2">@p.Category?.Name @(string.IsNullOrEmpty(p.Variety) ? "" : "· " + p.Variety)</div>
                    <div class="d-flex justify-content-between align-items-center mt-auto mb-2">
                        <span class="fw-bold fs-5 text-success">@p.Price.ToString("0.00") ₽</span>
                        <span class="badge @(p.Quantity > 0 ? "badge-success" : "badge-danger")">
                            @(p.Quantity > 0 ? $"В наличии: {p.Quantity}" : "Нет")
                        </span>
                    </div>
                    <div class="d-flex gap-2">
                        <form asp-controller="Cart" asp-action="AddToCart" method="post" class="flex-grow-1">
                            <input type="hidden" name="productId" value="@p.Id" />
                            <input type="hidden" name="returnUrl" value="/Favorites" />
                            <button type="submit" class="btn btn-success w-100" @(p.Quantity == 0 ? "disabled" : "")>В корзину</button>
                        </form>
                        <button type="button" class="btn btn-outline-danger fav-btn is-fav"
                                data-product-id="@p.Id" data-fav="1" data-remove-card
                                title="Убрать из избранного">
                            <span class="fav-icon">❤</span>
                        </button>
                    </div>
                </div>
            </div>
        </div>
    }
</div>
