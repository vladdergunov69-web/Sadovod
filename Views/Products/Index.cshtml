@model ProductListViewModel
@{
    ViewData["Title"] = "Каталог";
}
<h1 class="mb-3">Каталог товаров</h1>

<form method="get" class="row g-2 mb-4">
    <div class="col-md-5">
        <input type="text" name="search" value="@Model.Search" class="form-control" placeholder="Поиск по названию..." />
    </div>
    <div class="col-md-4">
        <select name="categoryId" class="form-select">
            <option value="">Все категории</option>
            @foreach (var c in Model.Categories)
            {
                if (Model.CategoryId == c.Id)
                {
                    <option value="@c.Id" selected>@c.Name</option>
                }
                else
                {
                    <option value="@c.Id">@c.Name</option>
                }
            }
        </select>
    </div>
    <div class="col-md-3 d-flex gap-2">
        <button class="btn btn-success flex-grow-1" type="submit">Найти</button>
        <a class="btn btn-outline-secondary" asp-action="Index">Сброс</a>
    </div>
</form>

@if (Model.Products.Count == 0)
{
    <div class="alert alert-info">По вашему запросу ничего не найдено.</div>
}
else
{
    <div class="row g-3">
        @foreach (var p in Model.Products)
        {
            <div class="col-12 col-sm-6 col-lg-4 col-xl-3">
                <div class="card sadovod-card h-100">
                    <a asp-action="Details" asp-route-id="@p.Id">
                        <img src="@(p.ImageUrl ?? "/images/products/no-photo.png")" class="card-img-top" alt="@p.Name" />
                    </a>
                    <div class="card-body d-flex flex-column">
                        <h6 class="card-title">
                            <a asp-action="Details" asp-route-id="@p.Id" class="text-reset text-decoration-none">@p.Name</a>
                        </h6>
                        <div class="small text-muted mb-2">@p.Category?.Name @(string.IsNullOrEmpty(p.Variety) ? "" : "· " + p.Variety)</div>
                        <div class="d-flex justify-content-between align-items-center mt-auto mb-2">
                            <span class="fw-bold fs-5 text-success">@p.Price.ToString("0.00") ₽</span>
                            <span class="badge @(p.Quantity > 0 ? "badge-success" : "badge-danger")">
                                @(p.Quantity > 0 ? $"В наличии: {p.Quantity}" : "Нет")
                            </span>
                        </div>
                        <form asp-controller="Cart" asp-action="AddToCart" method="post">
                            <input type="hidden" name="productId" value="@p.Id" />
                            <input type="hidden" name="returnUrl" value="@Context.Request.Path@Context.Request.QueryString" />
                            <button type="submit" class="btn btn-success w-100" @(p.Quantity == 0 ? "disabled" : "")>В корзину</button>
                        </form>
                    </div>
                </div>
            </div>
        }
    </div>

    @if (Model.TotalPages > 1)
    {
        <nav class="mt-4">
            <ul class="pagination justify-content-center">
                @for (int i = 1; i <= Model.TotalPages; i++)
                {
                    <li class="page-item @(i == Model.Page ? "active" : "")">
                        <a class="page-link" asp-action="Index"
                           asp-route-search="@Model.Search"
                           asp-route-categoryId="@Model.CategoryId"
                           asp-route-page="@i">@i</a>
                    </li>
                }
            </ul>
        </nav>
    }
}
