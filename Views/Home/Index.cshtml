@model IReadOnlyList<Product>
@{
    ViewData["Title"] = "Главная";
}

<section class="sadovod-hero rounded-4 p-5 mb-4 text-center">
    <h1 class="display-5 fw-bold mb-3">🌿 Лучшие семена для вашего сада</h1>
    <p class="lead mb-4">Гарантия всхожести · Доставка по России · Консультации агронома</p>
    <a class="btn btn-success btn-lg" asp-controller="Products" asp-action="Index">Перейти в каталог</a>
</section>

<h2 class="mb-3">Популярные товары</h2>
<div class="row g-3">
    @foreach (var p in Model)
    {
        <div class="col-12 col-sm-6 col-lg-3">
            <div class="card sadovod-card h-100">
                <div class="fav-overlay position-absolute top-0 end-0 m-2">
                    @await Html.PartialAsync("_FavoriteButton", p.Id)
                </div>
                <a asp-controller="Products" asp-action="Details" asp-route-id="@p.Id">
                    <img src="@(p.ImageUrl ?? "/images/products/no-photo.png")" class="card-img-top" alt="@p.Name" />
                </a>
                <div class="card-body d-flex flex-column">
                    <h6 class="card-title flex-grow-1">
                        <a asp-controller="Products" asp-action="Details" asp-route-id="@p.Id" class="stretched-link text-reset text-decoration-none">@p.Name</a>
                    </h6>
                    <div class="small text-muted mb-2">@p.Category?.Name</div>
                    <div class="d-flex justify-content-between align-items-center">
                        <span class="fw-bold fs-5 text-success">@p.Price.ToString("0.00") ₽</span>
                        <span class="badge @(p.Quantity > 0 ? "badge-success" : "badge-danger")">
                            @(p.Quantity > 0 ? "В наличии" : "Нет")
                        </span>
                    </div>
                </div>
            </div>
        </div>
    }
</div>
