@model LoginAuditFilterViewModel
@{
    ViewData["Title"] = "Аудит входов";
}
<h1 class="mb-3">Аудит входов</h1>

<form method="get" class="card sadovod-card mb-3">
    <div class="card-body row g-2">
        <div class="col-md-3">
            <label class="form-label">Логин</label>
            <input type="text" name="Login" value="@Model.Login" class="form-control" placeholder="email пользователя" />
        </div>
        <div class="col-md-2">
            <label class="form-label">Результат</label>
            <select name="Result" class="form-select">
                <option value="">Все</option>
                <option value="S" selected="@(Model.Result == "S")">Успех</option>
                <option value="F" selected="@(Model.Result == "F")">Неудача</option>
            </select>
        </div>
        <div class="col-md-3">
            <label class="form-label">С</label>
            <input type="date" name="DateFrom" value="@(Model.DateFrom?.ToString("yyyy-MM-dd"))" class="form-control" />
        </div>
        <div class="col-md-3">
            <label class="form-label">По</label>
            <input type="date" name="DateTo" value="@(Model.DateTo?.ToString("yyyy-MM-dd"))" class="form-control" />
        </div>
        <div class="col-md-1 d-flex align-items-end">
            <button class="btn btn-success w-100">Найти</button>
        </div>
    </div>
</form>

<div class="alert alert-warning py-2 small">
    ⚠️ Красным выделены логины с признаком подозрительной активности:
    последние 5 попыток входа неуспешны и совершены за последние 15 минут (возможен подбор пароля).
</div>

<div class="card sadovod-card">
    <div class="table-responsive">
        <table class="table align-middle mb-0">
            <thead>
                <tr>
                    <th>Дата входа</th>
                    <th>Логин</th>
                    <th>Результат</th>
                    <th>Пользователь</th>
                    <th>IP-адрес</th>
                    <th>Время выхода</th>
                </tr>
            </thead>
            <tbody>
                @if (Model.Entries.Count == 0)
                {
                    <tr><td colspan="6" class="text-center text-muted py-3">Записей не найдено.</td></tr>
                }
                @foreach (var e in Model.Entries)
                {
                    var suspicious = Model.SuspiciousLogins.Contains(e.Login);
                    <tr class="@(suspicious ? "table-danger" : "")">
                        <td class="text-nowrap">@e.LoginAt.ToString("dd.MM.yyyy HH:mm:ss")</td>
                        <td>
                            @e.Login
                            @if (suspicious)
                            {
                                <span class="badge badge-danger ms-1" title="Подозрительная активность">⚠️</span>
                            }
                        </td>
                        <td>
                            @if (e.Result == "S")
                            {
                                <span class="badge badge-success">Успех</span>
                            }
                            else
                            {
                                <span class="badge badge-danger">Неудача</span>
                            }
                        </td>
                        <td>@(e.User?.Login ?? "—")</td>
                        <td class="text-nowrap">@(string.IsNullOrEmpty(e.IpAddress) ? "—" : e.IpAddress)</td>
                        <td class="text-nowrap">@(e.LogoutAt?.ToString("dd.MM.yyyy HH:mm:ss") ?? "—")</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

@if (Model.TotalPages > 1)
{
    <nav class="mt-3">
        <ul class="pagination justify-content-center">
            @for (int i = 1; i <= Model.TotalPages; i++)
            {
                <li class="page-item @(i == Model.Page ? "active" : "")">
                    <a class="page-link" asp-action="Index"
                       asp-route-Login="@Model.Login"
                       asp-route-Result="@Model.Result"
                       asp-route-DateFrom="@(Model.DateFrom?.ToString("yyyy-MM-dd"))"
                       asp-route-DateTo="@(Model.DateTo?.ToString("yyyy-MM-dd"))"
                       asp-route-Page="@i">@i</a>
                </li>
            }
        </ul>
    </nav>
}
