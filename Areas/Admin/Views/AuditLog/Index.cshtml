@model AuditLogFilterViewModel
@{
    ViewData["Title"] = "Журнал аудита";
}
<h1 class="mb-3">Журнал аудита</h1>

<form method="get" class="card sadovod-card mb-3">
    <div class="card-body row g-2">
        <div class="col-md-3">
            <label class="form-label">Таблица</label>
            <select name="TableName" class="form-select">
                <option value="">Все</option>
                @foreach (var t in Model.AvailableTables)
                {
                    if (Model.TableName == t)
                    {
                        <option value="@t" selected>@t</option>
                    }
                    else
                    {
                        <option value="@t">@t</option>
                    }
                }
            </select>
        </div>
        <div class="col-md-2">
            <label class="form-label">Операция</label>
            <select name="Operation" class="form-select">
                <option value="">Все</option>
                <option value="I" selected="@(Model.Operation=="I")">Создание</option>
                <option value="U" selected="@(Model.Operation=="U")">Обновление</option>
                <option value="D" selected="@(Model.Operation=="D")">Удаление</option>
            </select>
        </div>
        <div class="col-md-3">
            <label class="form-label">С</label>
            <input type="date" name="DateFrom" value="@(Model.DateFrom?.ToString("yyyy-MM-dd"))" class="form-control" />
        </div>
        <div class="col-md-3">
            <label class="form-label">По</label>
            <input type="date" name="DateTo" value="@(Model.DateTo?.ToString("yyyy-MM-dd"))" class="form-control" />
        </div>
        <div class="col-md-1 d-flex align-items-end">
            <button class="btn btn-success w-100">Найти</button>
        </div>
    </div>
</form>

<div class="card sadovod-card">
    <div class="table-responsive">
        <table class="table align-middle mb-0">
            <thead><tr><th>Дата</th><th>Таблица</th><th>Операция</th><th>Пользователь</th><th>Старое</th><th>Новое</th></tr></thead>
            <tbody>
                @foreach (var e in Model.Entries)
                {
                    <tr>
                        <td class="text-nowrap">@e.ChangeDate.ToString("dd.MM.yyyy HH:mm:ss")</td>
                        <td>@e.TableName</td>
                        <td>
                            @{
                                var op = e.Operation switch { "I" => ("badge-success", "Создание"), "U" => ("badge-info", "Обновление"), "D" => ("badge-danger", "Удаление"), _ => ("badge-info", e.Operation) };
                            }
                            <span class="badge @op.Item1">@op.Item2</span>
                        </td>
                        <td>@(e.User?.Login ?? "—")</td>
                        <td><pre class="audit-json mb-0">@e.OldValue</pre></td>
                        <td><pre class="audit-json mb-0">@e.NewValue</pre></td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

@if (Model.TotalPages > 1)
{
    <nav class="mt-3">
        <ul class="pagination justify-content-center">
            @for (int i = 1; i <= Model.TotalPages; i++)
            {
                <li class="page-item @(i == Model.Page ? "active" : "")">
                    <a class="page-link" asp-action="Index"
                       asp-route-TableName="@Model.TableName"
                       asp-route-Operation="@Model.Operation"
                       asp-route-DateFrom="@(Model.DateFrom?.ToString("yyyy-MM-dd"))"
                       asp-route-DateTo="@(Model.DateTo?.ToString("yyyy-MM-dd"))"
                       asp-route-Page="@i">@i</a>
                </li>
            }
        </ul>
    </nav>
}
