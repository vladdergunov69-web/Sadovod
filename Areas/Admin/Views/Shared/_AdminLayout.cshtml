<!DOCTYPE html>
<html lang="ru" data-theme="light">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Админ — @(ViewData["Title"] ?? "Садовод")</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    @await RenderSectionAsync("Styles", required: false)
</head>
<body>
    <nav class="navbar navbar-expand-lg sadovod-navbar sticky-top">
        <div class="container-fluid">
            <a class="navbar-brand fw-bold" asp-area="" asp-controller="Home" asp-action="Index">🌱 Садовод · админ-панель</a>
            <button class="navbar-toggler" data-bs-toggle="collapse" data-bs-target="#adminNav"><span class="navbar-toggler-icon"></span></button>
            <div class="collapse navbar-collapse" id="adminNav">
                <ul class="navbar-nav me-auto">
                    <li class="nav-item"><a class="nav-link" asp-area="Admin" asp-controller="Dashboard" asp-action="Index">Дашборд</a></li>
                    <li class="nav-item"><a class="nav-link" asp-area="Admin" asp-controller="AdminProducts" asp-action="Index">Товары</a></li>
                    <li class="nav-item"><a class="nav-link" asp-area="Admin" asp-controller="Orders" asp-action="Index">Заказы</a></li>
                    <li class="nav-item"><a class="nav-link" asp-area="Admin" asp-controller="Users" asp-action="Index">Пользователи</a></li>
                    <li class="nav-item"><a class="nav-link" asp-area="Admin" asp-controller="AuditLog" asp-action="Index">Аудит</a></li>
                    <li class="nav-item"><a class="nav-link" asp-area="Admin" asp-controller="LoginAudit" asp-action="Index">Аудит входов</a></li>
                    <li class="nav-item"><a class="nav-link" asp-area="Admin" asp-controller="Settings" asp-action="Index">Настройки</a></li>
                    <li class="nav-item"><a class="nav-link" asp-area="Admin" asp-controller="Push" asp-action="Index">Push</a></li>
                </ul>
                <ul class="navbar-nav">
                    <li class="nav-item"><a class="nav-link" asp-area="" asp-controller="Home" asp-action="Index">← На сайт</a></li>
                    <li class="nav-item">
                        <form asp-area="" asp-controller="Account" asp-action="Logout" method="post" class="d-inline">
                            <button class="btn btn-link nav-link">Выход</button>
                        </form>
                    </li>
                    <li class="nav-item">
                        <button id="theme-toggle" type="button" class="btn btn-outline-light ms-2" aria-label="Переключить тему"></button>
                    </li>
                </ul>
            </div>
        </div>
    </nav>

    <main class="container-fluid my-4">
        @if (TempData["Info"] is string info)
        {
            <div class="alert alert-success alert-dismissible fade show" role="alert">
                @info
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }
        @RenderBody()
    </main>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
