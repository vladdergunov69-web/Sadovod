@model UserListViewModel
@{
    ViewData["Title"] = "Пользователи";
}
<h1 class="mb-3">Пользователи</h1>

<div class="card sadovod-card">
    <div class="table-responsive">
        <table class="table align-middle mb-0">
            <thead>
                <tr>
                    <th>ID</th>
                    <th>Логин (email)</th>
                    <th>ФИО</th>
                    <th>Телефон</th>
                    <th>Роль</th>
                    <th style="width: 280px;">Сменить роль</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var u in Model.Users)
                {
                    var isSelf = u.Id == Model.CurrentUserId;
                    <tr>
                        <td class="fw-bold">@u.Id</td>
                        <td>
                            @u.Login
                            @if (isSelf)
                            {
                                <span class="badge badge-info ms-1">вы</span>
                            }
                        </td>
                        <td>@u.FullName</td>
                        <td>@(string.IsNullOrEmpty(u.Phone) ? "—" : u.Phone)</td>
                        <td>
                            @{
                                var badge = u.RoleId == 1 ? "badge-success" : "badge-info";
                            }
                            <span class="badge @badge">@(u.Role?.Name ?? "—")</span>
                        </td>
                        <td>
                            @if (isSelf)
                            {
                                <span class="text-muted small">недоступно для себя</span>
                            }
                            else
                            {
                                <form asp-action="ChangeRole" method="post" class="d-flex gap-2">
                                    <input type="hidden" name="id" value="@u.Id" />
                                    <input type="hidden" name="page" value="@Model.Page" />
                                    <select name="roleId" class="form-select form-select-sm">
                                        @foreach (var r in Model.Roles)
                                        {
                                            if (r.Id == u.RoleId)
                                            {
                                                <option value="@r.Id" selected>@r.Name</option>
                                            }
                                            else
                                            {
                                                <option value="@r.Id">@r.Name</option>
                                            }
                                        }
                                    </select>
                                    <button class="btn btn-sm btn-outline-success">OK</button>
                                </form>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

@if (Model.TotalPages > 1)
{
    <nav class="mt-3">
        <ul class="pagination justify-content-center">
            @for (int i = 1; i <= Model.TotalPages; i++)
            {
                <li class="page-item @(i == Model.Page ? "active" : "")">
                    <a class="page-link" asp-action="Index" asp-route-page="@i">@i</a>
                </li>
            }
        </ul>
    </nav>
}
